{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "phoneNumber": { "type": "string", "description": "User's phone number" },
        "displayName": { "type": "string", "description": "User's display name" },
        "language": { "type": "string", "enum": ["en", "sw"], "description": "Preferred language" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "phoneNumber", "language"]
    },
    "SymptomReport": {
      "title": "Symptom Report",
      "description": "A diagnostic report generated by the symptom checker.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique report ID" },
        "userId": { "type": "string", "description": "Owner's UID" },
        "symptoms": { "type": "array", "items": { "type": "string" }, "description": "List of selected symptoms" },
        "customSymptom": { "type": "string", "description": "User-provided custom symptom description" },
        "condition": { "type": "string", "description": "Matched condition" },
        "recommendation": { "type": "string", "description": "Diagnostic recommendation" },
        "triageLevel": { "type": "string", "enum": ["emergency", "urgent", "routine", "self-care"], "description": "Triage urgency level" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was created" }
      },
      "required": ["id", "userId", "symptoms", "condition", "recommendation", "triageLevel", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/reports/{reportId}": {
      "schema": "SymptomReport",
      "description": "Collection of all diagnostic reports."
    }
  }
}
